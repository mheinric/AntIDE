{
	"name": "antide",
	"description": "An extension for writing and debugging ant assembly",
	"author": "Marc Heinrich",
	"license": "MIT",
	"version": "1.0.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/mheinric/AntIDE"
	},
	"publisher": "mheinric",
	"categories": [],
	"keywords": [],
	"engines": {
		"vscode": "^1.100.0"
	},
	"dependencies": {
		"vscode-languageclient": "^9.0.1"
	},
	"main": "./out/extension",
	"contributes": {
		"languages": [{
			"id": "aasm",
			"aliases": ["Ant Assembly File"],
			"extensions": [".aasm"],
			"configuration": "./language_configuration.json"
		}],
		"grammars": [{
			"language": "aasm",
			"scopeName": "source.abc",
			"path": "./aasm_syntax.json"
		}],
		"breakpoints": [
        {
            "language": "aasm"
        }],
		"debuggers": [
			{
				"type": "antide-debug",
				"label": "Ant assembly debugger",
				"languages": ["aasm"],
				"configurationAttributes": {
					"launch": {
						"properties": {
							"program": {
								"type": "string",
								"description": "Path to the ant assembly file to debug.",
								"default": "${file}"
							}
						}
					}
				}
			}
		],
		"configuration": {
			"type": "object",
			"title": "antide extension configuration",
			"properties": {
				"antideLSP.maxNumberOfProblems": {
					"scope": "resource",
					"type": "number",
					"default": 100,
					"description": "Controls the maximum number of problems produced by the server."
				},
				"antideLSP.trace.server": {
					"scope": "window",
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "Traces the communication between VS Code and the language server."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -b",
		"watch": "tsc -b -w",
		"lint": "eslint"
	},
	"devDependencies": {
		"@types/vscode": "^1.100.0",
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/node": "^22",
		"eslint": "^9.13.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}