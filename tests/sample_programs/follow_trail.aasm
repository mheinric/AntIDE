
.alias temp0 r0
.alias temp1 r1
.alias current_pos r2
.alias target_pos r3
.alias explore_dir r6
.alias ret r7

.const HOME_CH CH_BLUE
.const FOOD_CH CH_RED
.const AVOID_CH CH_YELLOW

.const KEEP_DIR_PC 95 ; Probability (in %) to keep current direction
; Position of the nest is 127, 127 to avoid overflow and negative values
.const HOME_POS 0x7F7F

main: 
RANDOM explore_dir 4
ADD explore_dir 1
SET current_pos HOME_POS

main_loop: 
CALL ret update_home_ch
CALL ret update_food_ch
CALL ret update_avoid_ch
CARRYING temp0
JEQ temp0 0 explore
JEQ temp0 1 go_home

explore:
; Look for food nearby
SENSE FOOD temp0
JEQ temp0 0 explore_no_food
CALL ret move_to
PICKUP
SET target_pos current_pos
JMP main_loop
explore_no_food:
; No food nearby, try to return to a previous known food location
JNE target_pos current_pos explore_dont_reset_target
SET target_pos 0
explore_dont_reset_target:
JEQ target_pos 0 explore_follow_trail ; If no target, just move at random
SET temp0 current_pos
AND temp0 0xFF00
SET temp1 target_pos
AND temp1 0xFF00
SUB temp1 temp0
JEQ temp1 0 explore_target_y
JLT temp1 0 explore_target_x_west
SET temp0 EAST
CALL ret move_to
JMP main_loop
explore_target_x_west:
SET temp0 WEST
CALL ret move_to
JMP main_loop
explore_target_y:
SET temp0 current_pos
AND temp0 0x00FF
SET temp1 target_pos
AND temp1 0x00FF
SUB temp1 temp0
JLT temp1 0 explore_target_y_south
SET temp0 NORTH
CALL ret move_to
JMP main_loop
explore_target_y_south:
SET temp0 SOUTH
CALL ret move_to
JMP main_loop

explore_follow_trail:
SMELL FOOD_CH temp0
JEQ temp0 0 explore_random
SNIFF AVOID_CH temp0 temp1
SNIFF FOOD_CH temp0 temp0
JGT temp1 temp0 explore_random
SNIFF FOOD_CH HERE temp1
JLT temp0 temp1 explore_follow_trail_local_max
JEQ temp0 temp1 explore_follow_trail_local_max
SMELL FOOD_CH temp0
CALL ret move_to
JMP main_loop

explore_follow_trail_local_max:
SET temp0 temp1
JGT temp0 250 explore_random
ADD temp0 1
SNIFF AVOID_CH HERE temp1
JLT temp0 temp1 explore_random
SUB temp0 temp1 
MARK AVOID_CH temp0

explore_random:
; No food nearby, we move in a random direction
RANDOM temp0 100
JLT temp0 KEEP_DIR_PC explore_no_change_dir
RANDOM explore_dir 4
ADD explore_dir 1
explore_no_change_dir: 
SET temp0 explore_dir
CALL ret move_to
JMP main_loop

go_home:
SENSE NEST temp0
JEQ temp0 0 go_home_no_nest
; There is a nest nearby, we move towards this direction
CALL ret move_to
DROP
JMP main_loop
go_home_no_nest:
; Look for a home pheromone trail nearby
SMELL HOME_CH temp0
JEQ temp0 0 go_home_no_phero
; There is a pheormone trail we follow it
CALL ret move_to
JMP main_loop
go_home_no_phero:
; There is no pheromone nearby we use the current position to go back home
SET temp0 current_pos
AND temp0 0xFF00
SET temp1 HOME_POS
AND temp1 0xFF00
SUB temp1 temp0
JEQ temp1 0 go_home_no_phero_y
JLT temp1 0 go_home_no_phero_x_west
SET temp0 EAST
CALL ret move_to
JMP main_loop
go_home_no_phero_x_west:
SET temp0 WEST
CALL ret move_to
go_home_no_phero_y:
SET temp0 current_pos
AND temp0 0x00FF
SET temp1 HOME_POS
AND temp1 0x00FF
SUB temp1 temp0
JLT temp1 0 go_home_no_phero_y_south
SET temp0 NORTH
CALL ret move_to
JMP main_loop
go_home_no_phero_y_south:
SET temp0 SOUTH
CALL ret move_to
JMP main_loop

update_home_ch:
; Check if there is a nest nearby
SENSE NEST temp0
JEQ temp0 0 update_home_ch_no_nest
; A nest is present, set the trail to the max
MARK HOME_CH 255
JMP update_home_ch_end
update_home_ch_no_nest:
; No nest is present, update the value here to the max of the neighbors - 1
SMELL HOME_CH temp0
JEQ temp0 0 update_home_ch_end
SNIFF HOME_CH temp0 temp0
SUB temp0 1
SNIFF HOME_CH HERE temp1
JLT temp0 temp1 update_home_ch_end
SUB temp0 temp1
MARK HOME_CH temp0
update_home_ch_end:
JMP ret

update_food_ch:
SENSE FOOD temp0
JEQ temp0 0 update_food_ch_no_food
; food is present, set the trail to the max
MARK FOOD_CH 255
JMP update_food_ch_end
update_food_ch_no_food:
; No food is present, update the value here to the max of the neighbors - 1
SMELL FOOD_CH temp0
JEQ temp0 0 update_food_ch_end
SNIFF FOOD_CH temp0 temp0
SUB temp0 1
SNIFF FOOD_CH HERE temp1
JLT temp0 temp1 update_food_ch_end
SUB temp0 temp1
MARK FOOD_CH temp0
update_food_ch_end:
JMP ret

update_avoid_ch:
SNIFF FOOD_CH HERE temp0
JEQ temp0 0 update_avoid_ch_end
SMELL AVOID_CH temp0
JEQ temp0 0 update_avoid_ch_end
SNIFF FOOD_CH temp0 temp1
SNIFF AVOID_CH temp0 temp0
JGT temp1 temp0 update_avoid_ch_end
SUB temp0 1
SNIFF AVOID_CH HERE temp1
JLT temp0 temp1 update_avoid_ch_end
SUB temp0 temp1
MARK AVOID_CH temp0
update_avoid_ch_end:
JMP ret



move_to: 
PROBE temp0 temp1
JNE temp1 WALL move_to_exec
; There is a wall in the specified direction, do nothing
JMP ret
move_to_exec:
MOVE temp0
JEQ temp0 EAST move_to_east
JEQ temp0 SOUTH move_to_south
JEQ temp0 WEST move_to_west
move_to_north:
ADD current_pos 0x0001
JMP ret
move_to_east:
ADD current_pos 0x0100
JMP ret
move_to_south:
SUB current_pos 0x0001
JMP ret
move_to_west:
SUB current_pos 0x0100
JMP ret

